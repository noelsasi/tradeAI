# ── Node API ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database (NeonDB or any Postgres)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Redis
REDIS_URL=redis://localhost:6379

# AI service (Python FastAPI)
AI_SERVICE_URL=http://localhost:8000

# File storage (Cloudflare R2 — leave blank for local dev)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tradeai-uploads
R2_PUBLIC_URL=

# ── Python AI Service ──────────────────────────────────────────────────────────
# Options: openai | anthropic | azure_openai
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_FAST_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_SMART_DEPLOYMENT=gpt-4o

MAX_FILE_SIZE_MB=10
REQUEST_TIMEOUT_SECONDS=30

# ── Shared ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
API_KEY=change-me-min-32-chars
