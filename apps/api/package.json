{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:sanctions": "tsx src/infrastructure/db/seed-sanctions.ts",
    "seed:sanctions:force": "tsx src/infrastructure/db/seed-sanctions.ts --force"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@types/node": "^24.12.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.4.0",
    "ioredis": "^5.11.1",
    "postgres": "^3.4.9",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/ioredis": "^5.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.4",
    "typescript": "~6.0.2",
    "vitest": "^4.1.8"
  }
}
